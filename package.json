{
  "name": "binsight-portal-cliente",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3001 --host=localhost",
    "build": "vite build",
    "preview": "vite preview --port=3001 --host=localhost",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && firebase deploy --only hosting:connect-binsight,functions:cliente --project comercial-binsight",
    "deploy:hosting": "npm run build && firebase deploy --only hosting:connect-binsight --project comercial-binsight",
    "deploy:notify": "node scripts/deploy-connect-notify.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "recharts": "^2.15.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
